# ─── Application ─────────────────────────────────────────────────
APP_NAME="invoice-ai-monitor"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Herd: http://invoice-ai-monitor.test  |  artisan serve: http://localhost:8000
APP_URL=http://invoice-ai-monitor.test

# ─── Logging ──────────────────────────────────────────────────────
# JSON structured log obbligatorio per governance (AGENTS.md) [A4]
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null

# ─── Database — connessione Laravel ───────────────────────────────
# MySQL locale (XAMPP / Herd Pro / MySQL Server autonomo)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=invoice_monitor
DB_USERNAME=root
DB_PASSWORD=

# ─── Cache (Laravel 11) ───────────────────────────────────────────
CACHE_STORE=file
# Compatibilità Laravel 10
CACHE_DRIVER=file

# ─── Session ──────────────────────────────────────────────────────
# No autenticazione nell'MVP [A2] — valori minimi richiesti da Laravel
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Broadcasting / Filesystem ────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# ─── Tabella sorgente fatture [A1] [A5] ───────────────────────────
# Nome tabella (o view SQL read-only) già esistente nel DB di fatturazione.
# Cambiare se lo schema reale ha nome diverso — vedi SPEC.md §Rischi R1.
INVOICE_QUEUE_TABLE=invoices_queue

# ─── Semaforo — soglie configurabili ──────────────────────────────
# VERDE  : pending <= YELLOW_PENDING AND errori <= YELLOW_ERRORS
# GIALLO : pending > YELLOW_PENDING  OR  errori > YELLOW_ERRORS
# ROSSO  : pending > RED_PENDING     OR  errori > RED_ERRORS
SEMAFORO_YELLOW_PENDING=10
SEMAFORO_YELLOW_ERRORS=3
SEMAFORO_RED_PENDING=50
SEMAFORO_RED_ERRORS=10

# ─── Dashboard — polling [A6] ─────────────────────────────────────
# Intervallo refresh lato client in secondi
DASHBOARD_REFRESH_SECONDS=60

# ─── Cache snapshot — TTL ─────────────────────────────────────────
# Riduce query ridondanti al MySQL (max 10 utenti simultanei — R3)
CACHE_TTL_SECONDS=30

# ─── Seeder — scenario di test ────────────────────────────────────
# Valori: verde | giallo | rosso
SEED_SCENARIO=verde

# ─── AI — provider [M2 / M3] ─────────────────────────────────────
# Seleziona il provider AI per la chat (ChatService).
# Valori: gemini | openrouter
AI_PROVIDER=openrouter

# ─── OpenRouter ────────────────────────────────────────────────────
# API OpenAI-compatibile. Chiave su https://openrouter.ai/keys
# Modello consigliato (piano free): meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ─── Gemini API (alternativa) ─────────────────────────────────────
# Ottenere la chiave su https://aistudio.google.com/app/apikey
# Cambiare AI_PROVIDER=gemini per usare questo provider.
GEMINI_API_KEY=
AI_MODEL=gemini-2.0-flash
AI_MAX_TOKENS=512
AI_TEMPERATURE=0.3
AI_RETRY_DELAY=2

# ─── Spiegami dinamico [M2] ───────────────────────────────────────
# Se true: ExplainerService chiama Gemini per spiegazioni contestuali.
# Se false o se Gemini non è disponibile: fallback ai template statici M0.
EXPLAINER_USE_LLM=true
